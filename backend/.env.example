# =============================================
# SERVER CONFIGURATION
# =============================================
NODE_ENV=development
# Dùng 5001 (trên Windows port 5000 thường bị chiếm; code dev tự đổi 5000→5001)
PORT=5001

# =============================================
# DATABASE (MongoDB Local)
# =============================================
MONGODB_URI=mongodb://localhost:27017/trello-clone

# =============================================
# JWT SECRETS (Bắt buộc - đổi sang chuỗi bí mật mạnh cho production)
# =============================================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# CLOUDINARY (Đăng ký miễn phí: https://cloudinary.com)
# Copy từ Dashboard → API Keys. Không commit key thật lên git.
# =============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =============================================
# FRONTEND URL (Để CORS hoạt động)
# =============================================
FRONTEND_URL=http://localhost:5173

# =============================================
# EMAIL (Optional - Comment lại nếu chưa dùng)
# =============================================
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@trello-clone.com

# =============================================
# OAUTH (Optional - chỉ cần khi dùng Social Login)
# =============================================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret

# =============================================
# AI (Optional - nếu không cấu hình sẽ tự fallback rule-based)
# =============================================
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# =============================================
# BOOTSTRAP ADMIN (Optional - dùng cho scripts/bootstrap-admin.js)
# =============================================
# ADMIN_NAME=System Admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=StrongPassword123!
# ADMIN_FORCE_PASSWORD_RESET=false

# =============================================
# SECURITY SETTINGS
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=5242880