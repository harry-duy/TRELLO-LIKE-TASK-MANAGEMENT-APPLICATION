@startuml
autonumber
actor UserA as "User A (Browser)"
participant FrontendA as "Frontend (User A)"
participant API as "Backend API"
database DB as "MongoDB"
participant Socket as "Socket.io Server"
participant FrontendB as "Frontend (User B)"

UserA -> FrontendA : Drag card to target list
FrontendA -> API : PUT /api/cards/:id/move\n{ listId, position, boardId }
API -> DB : Update card.list + card.position
DB --> API : Updated card
API -> DB : Insert Activity(card_moved)
API -> Socket : emit card:moved(board room)
API --> FrontendA : 200 OK + updated card
Socket --> FrontendB : card:moved event
FrontendA -> FrontendA : invalidate/refetch board query
FrontendB -> FrontendB : invalidate/refetch board query

alt API error
  API --> FrontendA : 4xx/5xx error
  FrontendA -> FrontendA : rollback/reload board state
end

@enduml
